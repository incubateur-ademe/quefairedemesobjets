# Infrastructure commands (OpenTofu / Terragrunt / Scaleway)
#
# Preview environments bootstrap: see
# docs/reference/infrastructure/preview-environments.md

# Loading environment variables from the repo root .env if present
ifneq (,$(wildcard ../.env))
    include ../.env
    export
endif

REPO = $(shell gh repo view --json nameWithOwner -q .nameWithOwner)

# Terragrunt reads the Scaleway credentials both as provider auth (SCW_*)
# and as TF vars for the S3 state backend generated by root.hcl; the AWS_*
# pair is consumed by the backend's AWS SDK.
export TF_VAR_access_key      = $(SCW_ACCESS_KEY)
export TF_VAR_secret_key      = $(SCW_SECRET_KEY)
export TF_VAR_project_id      = $(SCW_DEFAULT_PROJECT_ID)
export TF_VAR_organization_id = $(SCW_DEFAULT_ORGANIZATION_ID)
export AWS_ACCESS_KEY_ID      = $(SCW_ACCESS_KEY)
export AWS_SECRET_ACCESS_KEY  = $(SCW_SECRET_KEY)
export AWS_DEFAULT_REGION     = fr-par

.PHONY: check-scw-credentials
check-scw-credentials:
	@for v in SCW_ACCESS_KEY SCW_SECRET_KEY SCW_DEFAULT_PROJECT_ID SCW_DEFAULT_ORGANIZATION_ID; do \
	  [ -n "$$(printenv "$$v" || true)" ] || { echo "$$v is not set"; exit 1; }; \
	done

.PHONY: check-gh
check-gh:
	@which gh > /dev/null || { echo "gh (GitHub CLI) is not installed"; exit 1; }
	@gh auth status > /dev/null || { echo "gh is not authenticated, run: gh auth login"; exit 1; }

# Create the GitHub `preview` environment and push the secrets the preview
# workflows read. PREVIEW_SECRET_KEY is generated when not provided.
.PHONY: preview-github-env
preview-github-env: check-gh check-scw-credentials
	@[ -n "$(SCALEWAY_DOCKER_SECRET)" ] || { echo "SCALEWAY_DOCKER_SECRET is not set (registry push credential)"; exit 1; }
	@[ -n "$(SAMPLE_DB_URI)" ] || { echo "SAMPLE_DB_URI is not set (postgres URI of the preprod sample DB)"; exit 1; }
	@echo "Creating GitHub environment 'preview' on $(REPO)…"
	@gh api -X PUT "repos/$(REPO)/environments/preview" > /dev/null
	@for s in SCW_ACCESS_KEY SCW_SECRET_KEY SCW_DEFAULT_PROJECT_ID SCW_DEFAULT_ORGANIZATION_ID SCALEWAY_DOCKER_SECRET SAMPLE_DB_URI; do \
	  printenv "$$s" | gh secret set "$$s" --env preview --repo "$(REPO)" && echo "✓ $$s"; \
	done
	@KEY="$${PREVIEW_SECRET_KEY:-$$(openssl rand -hex 32)}"; \
	  printf '%s' "$$KEY" | gh secret set PREVIEW_SECRET_KEY --env preview --repo "$(REPO)" && echo "✓ PREVIEW_SECRET_KEY"

# Apply the shared container namespace (lvao-preview) read by every per-PR
# container stack. Interactive on purpose: review the plan before approving.
.PHONY: preview-namespace
preview-namespace: check-scw-credentials
	cd environments/preview/namespace && terragrunt init && terragrunt apply

.PHONY: preview-label
preview-label: check-gh
	gh label create preview \
	  --repo "$(REPO)" \
	  --description "Deploy a preview environment for this PR" \
	  --color 0E8A16 \
	  --force

# Full one-time bootstrap of the preview environments feature
.PHONY: preview-bootstrap
preview-bootstrap: preview-github-env preview-namespace preview-label
	@echo
	@echo "Preview environments bootstrapped. Add the 'preview' label to a PR to try it."
