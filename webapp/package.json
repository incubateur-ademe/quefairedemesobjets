{
  "type": "module",
  "scripts": {
    "build": "parcel build",
    "lint": "eslint . --fix",
    "format:check": "prettier --check static/to_compile",
    "format": "prettier static/to_compile --write",
    "test": "jest ./static/to_compile",
    "watch": "parcel watch --no-hmr",
    "e2e_test": " npx playwright test --update-snapshots"
  },
  "source": [
    "static/to_compile/admin-categorie-widget.ts",
    "static/to_compile/admin-map-widget.ts",
    "static/to_compile/admin.ts",
    "static/to_compile/embed/assistant.ts",
    "static/to_compile/embed/carte.ts",
    "static/to_compile/embed/formulaire.ts",
    "static/to_compile/embed/infotri-configurator.ts",
    "static/to_compile/embed/infotri.ts",
    "static/to_compile/infotri-child.ts",
    "static/to_compile/qfdmd.ts",
    "static/to_compile/qfdmo.ts"
  ],
  "targets": {
    "default": {
      "distDir": "./static/compiled"
    }
  },
  "browserslist": [
    "defaults",
    "iOS 14"
  ],
  "@parcel/transformer-css": {
    "errorRecovery": true
  },
  "prettier": {
    "trailingComma": "all",
    "printWidth": 88,
    "semi": false
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@gouvfr/dsfr": "^1.14",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.23",
    "@iframe-resizer/child": "^5.5.9",
    "@iframe-resizer/parent": "^5.5.9",
    "@sentry/browser": "^10.46.0",
    "bowser": "^2.14.1",
    "carte-facile": "^0.9.0",
    "eslint-config-prettier": "^10.1.8",
    "maplibre-gl": "^5.23.0",
    "posthog-js": "^1.365.0",
    "stimulus-use": "^0.52.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@parcel/optimizer-svgo": "^2.16.4",
    "@parcel/transformer-inline-string": "^2.16.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "buffer": "^6.0.3",
    "eslint": "^10.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lodash": "^4.18.1",
    "parcel": "^2.16.4",
    "postcss": "^8.5.9",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.2",
    "svgo": "^4.0.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "optionalDependencies": {
    "@parcel/watcher-linux-x64-glibc": "^2.5.6"
  }
}
